# Layer 1 (raw archive) is local-only by default.
# Real harvested data must NOT be committed (it contains PII, private threads,
# transcripts, etc.). Worked examples under raw/examples/ ARE committed so the
# schema's worked example is reproducible from a fresh clone — see ADR-0001.
/raw/*
!/raw/examples/
!/raw/examples/**

# Per-checkout content config (absolute paths, per-machine). Schema documented
# in .assistant.local.json.example.
/.assistant.local.json

# Harvester credentials only. Dedup state + allow/deny lists + daily digests
# ARE tracked (in the vault) so cross-machine harvest stays consistent.
.harvest/*-credentials.json
.harvest/*-token.json
.harvest/*-credentials/

# Standard Python / node detritus (pre-emptive — children #3+ may add tooling).
__pycache__/
*.pyc
.venv/
venv/
node_modules/
.DS_Store
