# Layer 1 (raw archive) is local-only by default.
# Real harvested data must NOT be committed (it contains PII, private threads,
# transcripts, etc.). Worked examples under raw/examples/ ARE committed so the
# schema's worked example is reproducible from a fresh clone — see ADR-0001.
/raw/*
!/raw/examples/
!/raw/examples/**

# Layer 2 (memory objects). Same policy as raw: real harvest output is local-only
# (or lives in the content vault, per #12). Only committed memory under examples/
# is the worked example + fixture-derived test outputs.
# This closes the F1 fire path the challenger flagged on PR #17: a fallback-mode
# harvest writes to memory/<source-kind>/ which would otherwise be a tracked
# directory next to the fixture outputs, indistinguishable on `git status`.
/memory/*
!/memory/examples/
!/memory/examples/**

# Per-checkout content config (absolute paths, per-machine). Schema documented
# in .assistant.local.json.example.
/.assistant.local.json

# Harvester local state stays excluded in Phase 1 of #12. Dedup keys today
# include absolute filesystem paths (see harvest.py::_FolderSource.dedupe_key)
# which are NOT cross-machine portable. Phase 2 of #12 will (a) make dedup keys
# content-root-relative or content-hash-only, and (b) move the state files to
# the vault repo for cross-machine consistency. Until both land, .harvest/
# remains local-only.
/.harvest/

# Metrics events + snapshots (#41) stay local-only. Same rationale as
# .harvest/: contains user-tied event metadata (topic keywords, latencies)
# that's bounded but not for cross-machine sharing without explicit consent.
/.metrics/

# Standard Python / node detritus (pre-emptive — children #3+ may add tooling).
__pycache__/
*.pyc
.venv/
venv/
node_modules/
.DS_Store
